{
  "expo": {
    "name": "Superbuket Delivery",
    "slug": "superbuket-delivery",
    "owner": "prathamkaushik2002",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.superbuket.delivery"
    },
    "android": {
      "package": "com.superbuket.delivery",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Superbucket Delivery to use your location while delivering orders."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "59f55314-5f69-43f3-9563-a686150ebbfa"
      }
    }
  }
}
